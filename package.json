{
  "name": "slate-editor",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "nuxt build && electron-builder",
    "electron:preview": "NODE_ENV=production electron ."
  },
  "dependencies": {
    "@tiptap/extension-link": "^2.10.4",
    "@tiptap/extension-task-item": "^2.10.4",
    "@tiptap/extension-task-list": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@tiptap/vue-3": "^2.10.4",
    "@vueuse/core": "^12.2.0",
    "nuxt": "^3.14.1592",
    "nuxt-icon": "1.0.0-beta.7",
    "vue": "latest",
    "vue-router": "latest"
  },
  "packageManager": "pnpm@9.14.2+sha512.6e2baf77d06b9362294152c851c4f278ede37ab1eba3a55fda317a4a17b209f4dbb973fb250a77abc463a341fcb1f17f17cfa24091c4eb319cda0d9b84278387",
  "devDependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@tailwindcss/typography": "^0.5.15",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.yourdomain.slate-editor",
    "productName": "Slate Editor",
    "mac": {
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "icon": "electron/icons/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
