{
  "name": "slate",
  "version": "1.0.0",
  "description": "A markdown editor for distraction-free writing",
  "author": {
    "name": "Kiran Johns",
    "email": "kiranjohns369@gmail.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "nuxt build && electron-builder",
    "electron:preview": "NODE_ENV=production electron ."
  },
  "dependencies": {
    "@pinia/nuxt": "^0.9.0",
    "@tiptap/extension-image": "^2.10.4",
    "@tiptap/extension-link": "^2.10.4",
    "@tiptap/extension-task-item": "^2.10.4",
    "@tiptap/extension-task-list": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@tiptap/vue-3": "^2.10.4",
    "@types/js-yaml": "^4.0.9",
    "@vueuse/core": "^12.2.0",
    "electron-store": "8.1.0",
    "js-yaml": "^4.1.0",
    "nuxt": "^3.14.1592",
    "nuxt-icon": "1.0.0-beta.7",
    "pinia": "^2.3.0",
    "tiptap-markdown": "^0.8.10",
    "vue": "latest",
    "vue-router": "latest"
  },
  "packageManager": "pnpm@9.14.2+sha512.6e2baf77d06b9362294152c851c4f278ede37ab1eba3a55fda317a4a17b209f4dbb973fb250a77abc463a341fcb1f17f17cfa24091c4eb319cda0d9b84278387",
  "devDependencies": {
    "@iconify-json/ph": "^1.2.2",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@tailwindcss/typography": "^0.5.15",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.yourdomain.slate-editor",
    "productName": "Slate",
    "mac": {
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "icon": "electron/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "dir",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "icon": "public/icons/icon.ico"
    },
    "linux": {
      "icon": "public/icons/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "protocols": [
      {
        "name": "workspace",
        "schemes": ["workspace"]
      }
    ]
  }
}
